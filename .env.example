PORT=3000
PUBLIC_BASE_URL=https://comet.mcpgw.app
SERVER_NAME=comet-mcpgw
SESSION_TTL_MS=1800000
AUTH_MODE=bearer
API_KEY=change-me
DISABLE_AUTH=false
MCP_ALLOWED_ORIGINS=
LOGGING_MODE=standard
REDIS_URL=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_CLIENT_ID_HEADER=x-client-id
# Chrome DevTools Protocol endpoint of a running Comet browser.
# On Docker Desktop, host.docker.internal points at the host machine.
COMET_CDP_URL=http://host.docker.internal:9222
